{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hr-jebar",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "pages_build_output_dir": "app/dist",
  "assets": {
    "directory": "app/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
